generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RESTAURANT
  SUPPLIER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RESTAURANT)
  createdAt DateTime @default(now())

  // Relations
  products Product[] @relation("SupplierProducts")
  orders   Order[]   @relation("RestaurantOrders")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  stock       Int
  imageUrl    String?
  supplierId  Int
  createdAt   DateTime @default(now())

  supplier   User        @relation("SupplierProducts", fields: [supplierId], references: [id])
  orderItems OrderItem[]
}

model Order {
  id           Int         @id @default(autoincrement())
  restaurantId Int
  status       OrderStatus @default(PENDING)
  totalPrice   Float
  createdAt    DateTime    @default(now())

  restaurant User        @relation("RestaurantOrders", fields: [restaurantId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}
